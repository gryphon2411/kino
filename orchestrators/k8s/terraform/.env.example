TF_VAR_environment=local

# Replace these example values before running task deploy.
TF_VAR_huggingface_hub_access_token=your_huggingface_token
TF_VAR_gemini_api_key=your_gemini_key

# Database Credentials
TF_VAR_mongodb_password=your_mongodb_password
TF_VAR_postgres_password=your_postgres_password
TF_VAR_redis_password=your_redis_password
TF_VAR_kafka_password=your_kafka_password
TF_VAR_rabbitmq_password=your_rabbitmq_password

# Optional: use a separate RabbitMQ admin password. Falls back to TF_VAR_rabbitmq_password if unset.
# TF_VAR_rabbitmq_admin_password=your_rabbitmq_admin_password

# Optional: override the conservative Minikube defaults used by playbook.yaml
# MINIKUBE_CPUS=4
# MINIKUBE_MEMORY=7800mb

TF_VAR_environment=local

# Replace these example values before running task deploy.
TF_VAR_huggingface_hub_access_token=your_huggingface_token
TF_VAR_gemini_api_key=your_gemini_key
TF_VAR_nvidia_api_key=your_nvidia_key
TF_VAR_agent_service_client_secret=replace_me_agent_secret

# Database Credentials
TF_VAR_mongodb_password=your_mongodb_password
TF_VAR_postgres_password=your_postgres_password
TF_VAR_redis_password=your_redis_password
TF_VAR_kafka_password=your_kafka_password
TF_VAR_rabbitmq_password=your_rabbitmq_password

# Immutable service image refs
# Copy these digest-pinned refs from the corresponding GitHub Actions publish run.
TF_VAR_auth_service_image_ref=gryphon2411/kino-auth_service@sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TF_VAR_data_service_image_ref=gryphon2411/kino-data_service@sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TF_VAR_trend_service_image_ref=gryphon2411/kino-trend_service@sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TF_VAR_generative_service_image_ref=gryphon2411/kino-generative_service@sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TF_VAR_ui_image_ref=gryphon2411/kino-ui@sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional when TF_VAR_enable_agent_service=true
# TF_VAR_agent_service_image_ref=gryphon2411/kino-agent_service@sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional: use a separate RabbitMQ admin password. Falls back to TF_VAR_rabbitmq_password if unset.
# TF_VAR_rabbitmq_admin_password=your_rabbitmq_admin_password

# Optional: increase the Mongo seed Job wall-clock budget when local registry pulls are slow.
# This covers image pull + container start + restore + promotion.
# TF_VAR_mongodb_seed_job_active_deadline_seconds=1800

# Optional: override the conservative Minikube defaults used by playbook.yaml
# MINIKUBE_CPUS=4
# MINIKUBE_MEMORY=7800mb

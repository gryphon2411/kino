# To separate traces from other Kino applications.
LANGSMITH_PROJECT=kino-agent-service

# Kino Curator defaults.
KINO_CURATOR_PROVIDER=google_genai
KINO_CURATOR_MODEL=gemini-3.1-flash-lite-preview
KINO_CURATOR_THINKING_LEVEL=high
KINO_DATA_SERVICE_URL=http://localhost:8082/api/v1/data
KINO_AUTH_SERVICE_URL=http://localhost:8081/api/v1/auth
KINO_AUTH_CLIENT_ID=agent-service
# KINO_AUTH_CLIENT_SECRET=

# Add API keys for connecting to LLM providers, data sources, and other integrations here.
#
# GOOGLE_API_KEY=
#
# NVIDIA NIM via ChatNVIDIA:
# KINO_CURATOR_PROVIDER=nvidia_nim
# Choose deepseek-ai/deepseek-v3.2 or moonshotai/kimi-k2.5.
# KINO_CURATOR_MODEL=deepseek-ai/deepseek-v3.2
# NVIDIA_API_KEY=
#
# Standalone Agent Server deployments also need Redis/Postgres and LangSmith
# deployment credentials. Keep those values out of this example file:
# REDIS_URI
# DATABASE_URI
# LANGSMITH_API_KEY
# LANGGRAPH_CLOUD_LICENSE_KEY

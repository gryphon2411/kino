{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "namespace": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean",
          "default": true
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "secret": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "username": {
          "type": "string"
        },
        "useExistingSecret": {
          "type": "boolean",
          "default": true
        }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        }
      },
      "required": ["name", "port", "targetPort", "type"],
      "additionalProperties": false
    },
    "statefulset": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string"
            },
            "tag": {
              "type": "string"
            }
          },
          "required": ["repository", "tag"],
          "additionalProperties": false
        },
        "containerPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "required": ["name", "replicas", "image", "containerPort"],
      "additionalProperties": false
    }
  },
  "required": ["namespace", "secret", "service", "statefulset"],
  "additionalProperties": false
}